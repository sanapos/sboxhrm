              ),
              const SizedBox(height: 12),
              _dialogField(daysCtrl, 'Số ngày', Icons.calendar_today),
            ]),
          ),
        ),
        actions: [
          TextButton(
              onPressed: () => Navigator.pop(ctx), child: const Text('Hủy')),
          ElevatedButton(
            onPressed: () async {
              await _apiService.createBatchLicenseKeys(
