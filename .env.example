# ═══════════════════════════════════════════════════════════════
# ZKTeco ADMS - Docker Environment Configuration
# Copy this file to .env and update values for your server
#
# ⭐ ĐỔI SERVER CHỈ CẦN ĐỔI 1 DÒNG: SERVER_HOST
# Tất cả URL khác (API, JWT, CORS, Email) tự tính từ SERVER_HOST
# ═══════════════════════════════════════════════════════════════

# ──── ⭐ SERVER IP/Domain (ĐỔI Ở ĐÂY) ────
# Thay bằng IP hoặc domain của server
# Ví dụ: 192.168.1.100, 103.56.78.90, mydomain.com
SERVER_HOST=192.168.1.100

# ──── Ports (thường không cần đổi) ────
API_PORT=7070
FLUTTER_PORT=3000

# ──── PostgreSQL Database ────
POSTGRES_DB=ZKTecoADMS
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Ti100600@

# ──── Redis Cache ────
REDIS_PASSWORD=redis123

# ──── JWT Security ────
# QUAN TRỌNG: Đổi secret keys cho production! (tối thiểu 32 ký tự)
JWT_ACCESS_SECRET=0hN6BbNJ2dwfCPykLrdeOeYd53Arr5jzNcyv0HQBd3I=
JWT_REFRESH_SECRET=GtkWOJijzhUF+qsTT875Jz81rcHAZQl29HqJbtcWnGA=
# JWT_ISSUER và JWT_AUDIENCE tự tính từ SERVER_HOST, KHÔNG cần đặt
# Chỉ đặt nếu muốn override (VD: dùng domain riêng cho API)
# JWT_ISSUER=https://api.mydomain.com
# JWT_AUDIENCE=https://api.mydomain.com
JWT_ACCESS_EXPIRATION=1500
JWT_REFRESH_EXPIRATION=120

# ──── Default Password ────
DEFAULT_EMPLOYEE_PASSWORD=Ti100600@

# ──── Email (SMTP) ────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_16_chars
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_FROM_NAME=ZKTeco ADMS
SMTP_ENABLE_SSL=true
